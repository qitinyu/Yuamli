{
  "name": "yuamli",
  "version": "1.0.0",
  "description": "Yuamli - 轻量级博客评论系统，支持 GitHub OAuth 授权登录、游客登录、Markdown 渲染、站长管理面板与邮件通知",
  "type": "module",
  "main": "src/server/index.ts",
  "bin": {
    "yuamli": "./src/server/index.ts"
  },
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "build": "npm run build:client",
    "build:client": "vite build --config vite.client.config.ts",
    "start": "node --import tsx src/server/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "src/",
    "dist/",
    "README.md",
    "docs/",
    "LICENSE"
  ],
  "keywords": [
    "comment-system",
    "blog-comments",
    "astro",
    "github-oauth",
    "markdown",
    "admin-panel",
    "yuamli"
  ],
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "marked": "^14.1.0",
    "nodemailer": "^6.9.14",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/nodemailer": "^6.4.15",
    "@types/uuid": "^10.0.0",
    "astro": "^4.16.0",
    "@astrojs/preact": "^3.5.1",
    "preact": "^10.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "@preact/preset-vite": "^2.9.1"
  },
  "peerDependencies": {
    "preact": "^10.0.0",
    "astro": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "preact": { "optional": true },
    "astro": { "optional": true }
  },
  "engines": { "node": ">=18.0.0" }
}