# Yuamli 留言系统环境变量配置
# 复制此文件为 .env.local 并填入你的值

# === GitHub OAuth (必填，用于 GitHub 登录) ===
# 1. 前往 https://github.com/settings/developers 创建 OAuth App
# 2. Authorization callback URL 填: http://localhost:3000/api/auth/github/callback
#    (部署到 CF Pages 后改为: https://your-domain.pages.dev/api/auth/github/callback)
# 3. 将获得的 Client ID 和 Client Secret 填入下方

# 前端使用（公开，会暴露在浏览器中）
NEXT_PUBLIC_GITHUB_CLIENT_ID=你的_GitHub_Client_ID

# 后端使用（保密，不要提交到 Git）
GITHUB_CLIENT_ID=你的_GitHub_Client_ID
GITHUB_CLIENT_SECRET=你的_GitHub_Client_Secret